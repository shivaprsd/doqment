{
  "manifest_version": 2,
  "version": "0.2",

  "name": "doqment PDF Reader",
  "short_name": "doqment",
  "description": "Mozilla's HTML5 PDF Viewer with Reader-mode add-on.",
  "author": "Shiva Prasad",
  "homepage_url": "https://github.com/shivaprsd/doqment",
  "icons": {
    "48": "images/icon.png",
    "96": "images/icon@2x.png",
    "128": "images/icon@3x.png"
  },

  "permissions": ["webNavigation", "*://*/*.pdf"],
  "background": {
    "scripts": ["scripts/background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_icon": {
      "19": "images/button.png",
      "38": "images/button@2x.png"
    },
    "default_title": "Open PDF Reader in New Tab"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "mac": "MacCtrl+Q",
        "default": "Alt+Q"
      },
      "description": "Open PDF Reader in New Tab"
    }
  }
}
